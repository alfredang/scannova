# Scannova API Keys
# Copy this file to .env and fill in your keys

# Google Gemini API Key (Primary AI) - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Fallback AI) - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server port
PORT=3001
